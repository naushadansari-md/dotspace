{
  "custom/notification": {
    "tooltip": true,
    "format": "{icon} {text}",
    "format-icons": {
      "notification": "",
      "none": "",
      "dnd-notification": "",
      "dnd-none": ""
    },
    "return-type": "json",
    "exec": "/usr/bin/swaync-client -swb",
    "on-click": "/usr/bin/swaync-client -t -sw",
    "on-click-right": "/usr/bin/swaync-client -d -sw",
    "on-click-middle": "swaync-client -C",
    "escape": true
  }
}