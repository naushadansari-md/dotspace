[Unit]
Description=Power-aware swayidle (AC/BAT) with warning + lock (niri)
Documentation=man:swayidle(1)
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.config/niri/scripts/swayidle-power.sh
Restart=on-failure
RestartSec=1

[Install]
WantedBy=graphical-session.target