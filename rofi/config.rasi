configuration {
    modi: "drun,run,window";
    show-icons: true;
    icon-theme: "Adwaita";
    drun-display-format: "{name}";
    display-drun: "Apps";
    display-run: "Run";
    display-window: "Windows";
    matching: "fuzzy";
    sort: true;

    kb-cancel: "Escape,MousePrimary";
    hover-select: true;
}