configuration {
    modi: "drun,run,window";
    show-icons: true;
    icon-theme: "Papirus";
    drun-display-format: "{name}";
    display-drun: "Apps";
    display-run: "Run";
    display-window: "Windows";
    matching: "fuzzy";
    sort: true;
    case-sensitive: false;
    cycle: true;

    kb-cancel: "Escape";
    hover-select: true;

    me-select-entry: "";
    me-accept-entry: "MousePrimary";
}