configuration {
  modi: "drun,run,window";
  show-icons: true;
  icon-theme: "Adwaita";
  drun-display-format: "{name}";
  display-drun: "Apps";
  display-run: "Run";
  display-window: "Windows";
  matching: "fuzzy";
  sort: true;

  /* Wayland */
  /* If you use rofi-wayland, this is fine; no X11-only options here. */
}